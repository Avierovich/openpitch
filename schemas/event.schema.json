{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpitch.dev/schemas/event-1.0.json",
  "title": "OpenPitch Event",
  "description": "A typed, confidence-scored event emitted when a tracked metric materially changes (FRD §8.5).",
  "type": "object",
  "required": ["id", "schema_version", "type", "company_id", "summary", "confidence", "detected_at"],
  "properties": {
    "id": { "type": "string", "description": "Stable event id, e.g. evt_8a1f" },
    "schema_version": { "type": "string", "const": "1.0" },
    "type": {
      "type": "string",
      "enum": [
        "funding_round",
        "valuation_update",
        "metric_update",
        "metric_threshold_crossed",
        "universe_entry",
        "universe_exit",
        "contradiction_flagged",
        "new_notable_customer",
        "leadership_change"
      ]
    },
    "company_id": { "type": "string" },
    "company_name": { "type": "string" },
    "summary": { "type": "string", "description": "Human-readable one-liner" },
    "payload": {
      "type": "object",
      "properties": {
        "metric": { "type": "string" },
        "previous": {},
        "current": {},
        "change_pct": { "type": "number" }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "estimate_type": { "type": "string", "enum": ["reported", "implied", "consensus"] },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string" },
          "published_at": { "type": "string" }
        }
      }
    },
    "detected_at": { "type": "string", "format": "date-time" }
  }
}
